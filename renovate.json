{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboardApproval"],
  "timezone": "Australia/Melbourne",
  "packageRules": [
    {
      "matchManagers": ["pep621"],
      "matchFileNames": ["pyproject.toml", "hatch.toml"],
      "automerge": true,
      "schedule": ["after 5pm on Friday"],
      "prCreation": "immediate",
      "prTitle": "Update Python dependencies",
      "prBody": "This PR updates the Python dependencies managed in pyproject.toml and hatch.toml.",
      "prBranchName": "renovate/python-deps",
      "prAssignees": ["@discreteds"]
    }
  ]
}